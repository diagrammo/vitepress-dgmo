{
  "name": "vitepress-dgmo",
  "version": "0.2.2",
  "description": "VitePress integration to render DGMO diagrams from fenced code blocks at build time. A markdown-it fence override backed by an async pre-render cache — `withDgmo()` wires both into your .vitepress/config.ts in one call.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diagrammo/vitepress-dgmo.git"
  },
  "homepage": "https://github.com/diagrammo/vitepress-dgmo#readme",
  "bugs": {
    "url": "https://github.com/diagrammo/vitepress-dgmo/issues"
  },
  "keywords": [
    "vitepress",
    "vite",
    "markdown-it",
    "dgmo",
    "diagrammo",
    "diagram",
    "diagrams",
    "markdown"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./client.css": "./dist/client.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "postbuild": "test -f dist/client.css && test -f dist/client.js",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@diagrammo/dgmo": ">=0.45.0 <1",
    "vitepress": "^1.0.0"
  },
  "dependencies": {
    "remark-dgmo": "^0.5.2"
  },
  "devDependencies": {
    "@diagrammo/dgmo": "^0.48.1",
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "markdown-it": "^14.1.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
